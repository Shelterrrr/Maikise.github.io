&lt;p&gt;&lt;img src=&quot;/post/cachelab/01.png&quot; alt=&quot;01&quot;&gt;&lt;/p&gt;
&lt;p&gt;&lt;img src=&quot;/post/cachelab/02.png&quot; alt=&quot;02&quot;&gt;&lt;/p&gt;
&lt;p&gt;&lt;img src=&quot;/post/cachela</summary>
      
    
    
    
    
